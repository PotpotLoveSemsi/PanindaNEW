<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.UserProfilePage"
             BackgroundColor="#F6F6F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Grid ColumnDefinitions="Auto,*">
                <Button Text="←"
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#C86DD7"
                        TextColor="White"
                        CornerRadius="20"
                        Clicked="OnBackClicked"/>

                <Label Text="USER PROFILE"
                       Grid.Column="1"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#C86DD7"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Profile Picture (tappable) -->
            <Border BackgroundColor="LightGray"
                    WidthRequest="160"
                    HeightRequest="160"
                    StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="80" />
                </Border.StrokeShape>
                <Grid>
                    <Image x:Name="ProfileImage" Source="dotnet_bot.png" Aspect="AspectFill" IsVisible="False" />
                    <Label x:Name="ProfileEmoji" Text="👤" FontSize="80" HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangeProfilePicture" />
                </Border.GestureRecognizers>
            </Border>

            <VerticalStackLayout Spacing="8">
                <Label Text="Store Owner Name" TextColor="Black"/>
                <Label x:Name="OwnerNameLabel" Text="Loading..." FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Store Name" TextColor="Black"/>
                <Label x:Name="StoreNameLabel" Text="Loading..." FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Phone Number" TextColor="Black"/>
                <Label x:Name="PhoneLabel" Text="Loading..." FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Location" TextColor="Black"/>
                <Label x:Name="LocationLabel" Text="Loading..." FontAttributes="Bold" TextColor="Black"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#CCCCCC" Margin="0,10"/>

            <VerticalStackLayout Spacing="8">
                <Label Text="Account" FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Settings" TextColor="Black"/>
                <Label Text="Edit Profile" TextColor="#C86DD7">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEditProfile"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="Order History" TextColor="#C86DD7">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOrderHistory"/>
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

            <!-- Upgrade to Premium (shown only for non‑premium) -->
            <StackLayout x:Name="PremiumUpgradeContainer">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="[ Upgrade to Premium ]" TextColor="#C86DD7" FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUpgradeClicked" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="🪙" FontSize="20" TextColor="#F4A300"/>
                </HorizontalStackLayout>
            </StackLayout>

            <!-- Premium Active message (shown only for premium users) -->
            <Label x:Name="PremiumActiveLabel"
                   Text="✨ Premium Active ✨"
                   TextColor="#2E7D32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   IsVisible="False" />

            <Button Text="LOGOUT"
                    BackgroundColor="#F4A300"
                    TextColor="Black"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="12"
                    Margin="0,20"
                    Clicked="OnLogoutClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>