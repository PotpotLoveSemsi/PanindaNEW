<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.NotificationPage"
             BackgroundColor="#F2EFEF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Border BackgroundColor="#A855F7"
                        Stroke="White"
                        StrokeThickness="1.5"
                        Padding="12,6"
                        StrokeShape="RoundRectangle 18">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked" />
                    </Border.GestureRecognizers>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="←" FontSize="16" TextColor="White" />
                        <Label Text="Back" FontSize="14" TextColor="White" />
                    </HorizontalStackLayout>
                </Border>

                <Label Text="NOTIFICATION"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#E5A823"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Border BackgroundColor="#E6E1E1" StrokeThickness="0" Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>

                <CollectionView x:Name="NotificationsList" ItemsLayout="VerticalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="2" Margin="0,10">
                                <Label Text="{Binding Title}" TextColor="#D9534F" FontAttributes="Bold"/>
                                <Label Text="{Binding Message}" TextColor="Black"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>