<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.NotificationPage"
             BackgroundColor="#F2EFEF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <HorizontalStackLayout Spacing="12">
                <Border BackgroundColor="#A855F7" Padding="12,6" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="← Back" TextColor="White"/>
                </Border>

                <Label Text="NOTIFICATIONS"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#E5A823"/>
            </HorizontalStackLayout>

            <Label Text="Latest orders appear first"
                   TextColor="Gray"
                   FontSize="14"/>

            <CollectionView x:Name="NotificationsList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="18"
                                Margin="0,6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Title}"
                                       FontSize="19"
                                       FontAttributes="Bold"
                                       TextColor="#D16BA5"/>
                                <Label Text="{Binding Message}"
                                       FontSize="15"
                                       TextColor="Black"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button x:Name="ViewMoreButton"
                    Text="View More"
                    BackgroundColor="#F4B400"
                    TextColor="Black"
                    FontAttributes="Bold"
                    CornerRadius="20"
                    HeightRequest="48"
                    IsVisible="False"
                    Clicked="OnViewMoreClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>