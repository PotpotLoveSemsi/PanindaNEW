<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.SmartRestockPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <Grid BackgroundColor="#D9D9D9" Padding="15" ColumnDefinitions="Auto,*">
                <Image Grid.Column="0" Source="logo.png" HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Grid.Column="1" />
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="15">

                <HorizontalStackLayout Spacing="12">
                    <Border BackgroundColor="#A855F7" Padding="12,6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="← Back" TextColor="White"/>
                    </Border>

                    <Label Text="SMART RESTOCK"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#A855F7"/>
                </HorizontalStackLayout>

                <Label Text="Based on sales trends + stock levels"
                       TextColor="#C084FC"
                       FontSize="14"/>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                    <Button Text="Select All" BackgroundColor="#E0E0E0" TextColor="Black"
                            CornerRadius="10" HeightRequest="35" Clicked="OnSelectAllClicked"/>
                    <Button Text="Clear All" BackgroundColor="#E0E0E0" TextColor="Black"
                            CornerRadius="10" HeightRequest="35" Clicked="OnClearAllClicked"/>
                </HorizontalStackLayout>

                <CollectionView x:Name="RestockSuggestionsList" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#F2F2F2" Padding="15" Margin="0,6" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              VerticalOptions="Center"/>

                                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                        <Label Text="{Binding Stock, StringFormat='Current Stock: {0}'}" TextColor="Gray"/>
                                        <Label Text="{Binding SuggestedOrder, StringFormat='Suggested Order: {0}'}" TextColor="#A855F7"/>

                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="Order Quantity:" TextColor="Black" VerticalOptions="Center"/>

                                            <Button Text="−"
                                                    WidthRequest="38"
                                                    HeightRequest="32"
                                                    Padding="0"
                                                    FontSize="18"
                                                    BackgroundColor="#666666"
                                                    TextColor="White"
                                                    CornerRadius="6"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnDecreaseQuantityClicked"/>

                                            <Button Text="+"
                                                    WidthRequest="38"
                                                    HeightRequest="32"
                                                    Padding="0"
                                                    FontSize="18"
                                                    BackgroundColor="#666666"
                                                    TextColor="White"
                                                    CornerRadius="6"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnIncreaseQuantityClicked"/>

                                            <Label Text="{Binding Quantity}"
                                                   TextColor="#A855F7"
                                                   FontSize="16"
                                                   WidthRequest="35"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <StackLayout x:Name="PremiumLockedContainer">
                    <Label Text="🔒 AI Forecast (Premium)" TextColor="Gray"/>
                    <Label Text="• Seasonal demand prediction" TextColor="Gray"/>
                    <Label Text="• Holiday-based suggestions" TextColor="Gray"/>
                    <Label Text="[ Unlock Premium ]" HorizontalOptions="Center" TextColor="#A855F7">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUnlockPremiumClicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </StackLayout>

                <StackLayout x:Name="PremiumUnlockedContainer" IsVisible="False">
                    <Label Text="✅ AI Forecast (Active)" TextColor="#2E7D32" FontAttributes="Bold"/>
                    <Label Text="• Seasonal demand prediction – enabled" TextColor="#1C1C1C"/>
                    <Label Text="• Holiday-based suggestions – enabled" TextColor="#1C1C1C"/>
                </StackLayout>

                <Button Text="CREATE ORDER"
                        BackgroundColor="#FBBF24"
                        TextColor="Black"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        Clicked="OnCreateOrderClicked"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>