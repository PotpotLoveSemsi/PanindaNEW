<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.EditProfilePage"
             BackgroundColor="#F6F6F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Title only -->
            <Label Text="EDIT PROFILE"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#C86DD7"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <Label Text="Store Owner Name" TextColor="Black"/>
            <Entry x:Name="OwnerNameEntry" Placeholder="Enter name" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Label Text="Store Name" TextColor="Black"/>
            <Entry x:Name="StoreNameEntry" Placeholder="Enter store name" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Label Text="Phone Number" TextColor="Black"/>
            <Entry x:Name="PhoneEntry" Placeholder="Enter number" Keyboard="Telephone" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Label Text="Store Address" TextColor="Black"/>
            <Entry x:Name="AddressEntry" Placeholder="Enter address" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Label Text="Email" TextColor="Black"/>
            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Label Text="New Password (optional)" TextColor="Black"/>
            <Entry x:Name="PasswordEntry" IsPassword="True" Placeholder="Leave blank to keep current" BackgroundColor="White" TextColor="Black" PlaceholderColor="Gray"/>

            <Button Text="SAVE CHANGES"
                    BackgroundColor="#F4A300"
                    TextColor="Black"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="12"
                    Margin="0,30"
                    Clicked="OnSaveClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>