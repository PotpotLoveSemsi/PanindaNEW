<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.InventoryPage"
             BackgroundColor="#F2F2F2">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Grid BackgroundColor="#D9D9D9" Padding="15" ColumnDefinitions="Auto,*">
                <Image Grid.Column="0" Source="logo.png" HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Grid.Column="1" />
            </Grid>

            <HorizontalStackLayout Spacing="12">
                <Border BackgroundColor="#A855F7" Padding="10,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="← Back" TextColor="White"/>
                </Border>

                <Label Text="INVENTORY"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#B455FF"/>
            </HorizontalStackLayout>

            <Border BackgroundColor="White" Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Entry x:Name="SearchEntry"
                       Placeholder="Search Item"
                       TextColor="Black"
                       PlaceholderColor="Gray"
                       TextChanged="OnSearchTextChanged"/>
            </Border>

            <CollectionView x:Name="ProductsCollectionView" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Padding="15" Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Category}" FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                <Label Text="{Binding Stock, StringFormat='Stock: {0}'}" TextColor="Black"/>
                                <Label Text="⚠ LOW STOCK"
                                       TextColor="Red"
                                       FontAttributes="Bold"
                                       IsVisible="{Binding IsLowStock}"/>

                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="24">
                                    <Label Text="−" TextColor="#B455FF" FontSize="24">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DecreaseStockCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <Label Text="{Binding Stock}" TextColor="#B455FF" FontSize="20"/>

                                    <Label Text="+" TextColor="#B455FF" FontSize="24">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding IncreaseStockCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ ADD PRODUCT"
                    BackgroundColor="#F4B400"
                    TextColor="Black"
                    CornerRadius="22"
                    HeightRequest="50"
                    Clicked="OnAddProductClicked"/>

            <Button Text="- REMOVE PRODUCT"
                    BackgroundColor="#F4B400"
                    TextColor="Black"
                    CornerRadius="22"
                    HeightRequest="50"
                    Clicked="OnRemoveProductClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>