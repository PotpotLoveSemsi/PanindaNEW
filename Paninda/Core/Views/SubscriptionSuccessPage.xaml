<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.SubscriptionSuccessPage"
             BackgroundColor="#F2EFEF">

    <VerticalStackLayout Padding="20" Spacing="30" VerticalOptions="Center">

        <Label Text="Subscription Successful!"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#C084FC"
               HorizontalOptions="Center"/>

        <Label Text="Welcome to Premium 💎"
               FontSize="20"
               HorizontalOptions="Center"
               TextColor="Black"/>

        <Button Text="Go to Dashboard"
                BackgroundColor="#E5A823"
                TextColor="Black"
                CornerRadius="10"
                HeightRequest="50"
                Clicked="OnGoDashboard"/>
    </VerticalStackLayout>
</ContentPage>