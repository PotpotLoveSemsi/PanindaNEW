<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.PremiumPage"
             BackgroundColor="#F2EFEF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="PANINDA PREMIUM"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#A855F7"
                   HorizontalOptions="Center"/>

            <Border BackgroundColor="White" Padding="22" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="₱200 / month"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#F4B400"
                           HorizontalOptions="Center"/>

                    <Label Text="Unlock premium dashboard insights"
                           TextColor="Black"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Padding="18" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Premium Benefits"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#A855F7"/>

                    <Label Text="📊 Sales Insights" TextColor="Black"/>
                    <Label Text="💰 Profit Tracking" TextColor="Black"/>
                    <Label Text="⚠ Low Stock Alerts" TextColor="Black"/>
                    <Label Text="📦 Inventory Monitoring" TextColor="Black"/>
                    <Label Text="✨ Enhanced Dashboard UI" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Select Payment Method"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                <Button x:Name="GCashBtn"
                        Text="GCash"
                        BackgroundColor="#A855F7"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        WidthRequest="120"
                        Clicked="OnGCashClicked"/>

                <Button x:Name="MayaBtn"
                        Text="Maya"
                        BackgroundColor="#A855F7"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        WidthRequest="120"
                        Clicked="OnMayaClicked"/>
            </HorizontalStackLayout>

            <Border BackgroundColor="White"
                    Padding="15"
                    StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label x:Name="QrTitleLabel"
                           Text="Select payment method first"
                           TextColor="Black"
                           HorizontalOptions="Center"/>

                    <Image x:Name="QrImage"
                           Source="gcash_qr.png"
                           WidthRequest="220"
                           HeightRequest="220"
                           Aspect="AspectFit"
                           IsVisible="False"/>
                </VerticalStackLayout>
            </Border>

            <Button Text="CONFIRM PAYMENT"
                    BackgroundColor="#F4B400"
                    TextColor="Black"
                    FontAttributes="Bold"
                    CornerRadius="18"
                    HeightRequest="52"
                    Clicked="OnConfirmClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>