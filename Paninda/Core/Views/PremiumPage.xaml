<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.PremiumPage"
             BackgroundColor="#F2EFEF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Title only (back arrow removed) -->
            <Label Text="PANINDA PREMIUM DETAILS"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#C084FC"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <Label Text="🤖 AI Demand Forecasting" FontAttributes="Bold" TextColor="Black"/>
            <Label Text="• Seasonal trends" TextColor="Black"/>
            <Label Text="• Holiday prediction" TextColor="Black"/>
            <Label Text="• Sales-based forecasting" TextColor="Black"/>

            <Label Text="📊 Advanced Sales Analytics" Margin="0,15,0,0" FontAttributes="Bold" TextColor="Black"/>
            <Label Text="• Reports (weekly/monthly)" TextColor="Black"/>
            <Label Text="• Sales graphs" TextColor="Black"/>
            <Label Text="• Profit tracking" TextColor="Black"/>

            <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,20,0,10"/>
            <Label Text="₱200 / month" FontSize="18" TextColor="Black"/>

            <Button Text="Subscribe Now"
                    BackgroundColor="#E5A823"
                    TextColor="Black"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnSubscribeClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>