<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.CreateSupplierOrderPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <!-- Header (unchanged) -->
            <Grid BackgroundColor="#D9D9D9" Padding="15" ColumnDefinitions="Auto,*,Auto,Auto">
                <Image Grid.Column="0" Source="logo.png" HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Grid.Column="1" />
                <Label Grid.Column="2" Text="🔔" FontSize="24" Margin="0,0,10,0" TextColor="Black" />
                <Label Grid.Column="3" Text="👤" FontSize="24" TextColor="Black">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Back arrow and title -->
                <HorizontalStackLayout>
                    <Label Text="←" FontSize="24" TextColor="#A855F7">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="CREATE SUPPLIER ORDER" FontSize="20" FontAttributes="Bold" TextColor="#A855F7" Margin="10,0,0,0"/>
                </HorizontalStackLayout>

                <!-- Supplier Picker with event handler -->
                <Label Text="Supplier" TextColor="#C084FC" FontSize="16"/>
                <Picker x:Name="SupplierPicker" 
                        Title="Select Supplier" 
                        TextColor="Black" 
                        TitleColor="Gray"
                        SelectedIndexChanged="OnSupplierSelected">
                    <Picker.Items>
                        <x:String>ABC Foods</x:String>
                        <x:String>XYZ Supply</x:String>
                        <x:String>YNS Snacks</x:String>
                        <x:String>TGS Hygienix</x:String>
                    </Picker.Items>
                </Picker>

                <Label Text="Items to Order" TextColor="#C084FC" FontSize="16" Margin="0,10,0,0"/>
                <CollectionView x:Name="OrderItemsList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Margin="0,5">
                                <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="Black"/>
                                <!-- Price label removed -->
                                <Label Text="{Binding Quantity, StringFormat='Quantity: {0}'}" TextColor="Gray"/>
                                <Label Text="{Binding Subtotal, StringFormat='Subtotal: ₱{0}'}" TextColor="#A855F7"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Expected Delivery" TextColor="#C084FC" FontSize="16" Margin="0,10,0,0"/>
                <Label x:Name="DeliveryDateLabel" Text="" TextColor="Black"/>

                <!-- Notify button starts disabled -->
                <Button x:Name="NotifyButton" 
                        Text="NOTIFY SUPPLIER" 
                        BackgroundColor="#FBBF24" 
                        TextColor="Black" 
                        FontAttributes="Bold" 
                        CornerRadius="10" 
                        HeightRequest="50" 
                        Margin="0,20,0,0" 
                        IsEnabled="False"
                        Clicked="OnNotifyClicked"/>

                <StackLayout x:Name="PriceEntryContainer" IsVisible="False">
                    <Label Text="Supplier Price (₱)" TextColor="#C084FC" FontSize="16" Margin="0,10,0,0"/>
                    <Entry x:Name="SupplierPriceEntry" Placeholder="Enter price from supplier" Keyboard="Numeric" TextColor="Black" PlaceholderColor="Gray"/>
                    <Button Text="CONFIRM ORDER" BackgroundColor="#FBBF24" TextColor="Black" FontAttributes="Bold" CornerRadius="10" HeightRequest="50" Margin="0,10,0,0" Clicked="OnConfirmClicked"/>
                </StackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>