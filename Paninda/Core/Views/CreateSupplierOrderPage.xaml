<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.CreateSupplierOrderPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <Grid BackgroundColor="#D9D9D9" Padding="15" ColumnDefinitions="Auto,*,Auto,Auto">
                <Image Grid.Column="0" Source="logo.png" HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Grid.Column="1" />
                <Label Grid.Column="2" Text="🔔" FontSize="24" Margin="0,0,10,0" TextColor="Black" />
                <Label Grid.Column="3" Text="👤" FontSize="24" TextColor="Black">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="15">

                <HorizontalStackLayout Spacing="12">
                    <Border BackgroundColor="#A855F7" Stroke="White" StrokeThickness="1.5" Padding="12,6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="← Back" TextColor="White" FontSize="14"/>
                    </Border>

                    <Label Text="CREATE SUPPLIER ORDER"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#A855F7"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Text="Supplier" TextColor="#C084FC" FontSize="16"/>

                <Picker x:Name="SupplierPicker"
                        Title="Select Supplier"
                        TextColor="Black"
                        TitleColor="Gray"
                        SelectedIndexChanged="OnSupplierSelected">
                    <Picker.Items>
                        <x:String>ABC Foods</x:String>
                        <x:String>XYZ Supply</x:String>
                        <x:String>YNS Snacks</x:String>
                        <x:String>TGS Hygienix</x:String>
                    </Picker.Items>
                </Picker>

                <Label Text="Items to Order" TextColor="#C084FC" FontSize="16"/>

                <CollectionView x:Name="OrderItemsList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#F2EFEF" Padding="12" Margin="0,5" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="Black"/>
                                    <Label Text="{Binding Quantity, StringFormat='Quantity: {0}'}" TextColor="Gray"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Expected Delivery" TextColor="#C084FC" FontSize="16"/>
                <Label x:Name="DeliveryDateLabel" Text="Will generate after notify" TextColor="Black"/>

                <Button x:Name="NotifyButton"
                        Text="NOTIFY SUPPLIER"
                        BackgroundColor="#FBBF24"
                        TextColor="Black"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        IsEnabled="False"
                        Clicked="OnNotifyClicked"/>

                <Border x:Name="PriceEntryContainer"
                        IsVisible="False"
                        BackgroundColor="#F2EFEF"
                        Padding="15"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Supplier Response" TextColor="#A855F7" FontAttributes="Bold"/>
                        <Label x:Name="GeneratedPriceLabel" TextColor="Black"/>
                        <Label x:Name="GeneratedEtaLabel" TextColor="Black"/>

                        <Button Text="CONFIRM ORDER"
                                BackgroundColor="#FBBF24"
                                TextColor="Black"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                HeightRequest="50"
                                Clicked="OnConfirmClicked"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>