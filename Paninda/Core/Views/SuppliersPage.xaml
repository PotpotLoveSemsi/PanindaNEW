<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.SupplierPage"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Title only (back button removed) -->
            <Label Text="SUPPLIERS"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#D16BA5"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <!-- Supplier cards unchanged -->
            <Border BackgroundColor="#EDEDED" StrokeThickness="0" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Label Text="ABC Foods" FontSize="18" TextColor="#D16BA5" FontAttributes="Bold"/>
                    <Label Text="Contact: 09123456789" TextColor="Black"/>
                    <Label Text="Products: Sardines, Noodles" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#EDEDED" StrokeThickness="0" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Label Text="XYZ Beverages" FontSize="18" TextColor="#D16BA5" FontAttributes="Bold"/>
                    <Label Text="Contact: 09234567890" TextColor="Black"/>
                    <Label Text="Products: Coke, Sprite" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#EDEDED" StrokeThickness="0" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Label Text="YNS Snacks" FontSize="18" TextColor="#D16BA5" FontAttributes="Bold"/>
                    <Label Text="Contact: 09234567890" TextColor="Black"/>
                    <Label Text="Products: Bread, Juice" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#EDEDED" StrokeThickness="0" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Label Text="TGS Hygienix" FontSize="18" TextColor="#D16BA5" FontAttributes="Bold"/>
                    <Label Text="Contact: 09234567890" TextColor="Black"/>
                    <Label Text="Products: Shampoo, Soap" TextColor="Black"/>
                </VerticalStackLayout>
            </Border>

            <Button Text="View Orders"
                    BackgroundColor="#F4A300"
                    TextColor="Black"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="55"
                    Margin="0,20,0,20"
                    Clicked="OnViewOrdersClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>