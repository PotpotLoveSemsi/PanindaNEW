<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.OrderHistoryPage"
             BackgroundColor="#F6F6F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="ORDER HISTORY"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#C86DD7"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <CollectionView x:Name="OrdersHistoryList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#EDEDED" StrokeThickness="0" Padding="15" Margin="0,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding OrderNumber}" TextColor="#C86DD7" FontAttributes="Bold"/>
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Supplier: " TextColor="#F4A300"/>
                                            <Span Text="{Binding SupplierName}" TextColor="Black"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="Items Ordered:" TextColor="#F4A300"/>
                                <Label Text="{Binding ItemsSummary}" TextColor="Black"/>
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Status: " TextColor="#F4A300"/>
                                            <Span Text="{Binding Status}" TextColor="Black"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Total Cost: " TextColor="#F4A300"/>
                                            <Span Text="{Binding TotalCost, StringFormat='₱{0}'}" TextColor="Black"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>