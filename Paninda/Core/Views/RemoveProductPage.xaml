<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.RemoveProductPage"
             BackgroundColor="#F2F2F2">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <Grid BackgroundColor="#D9D9D9" Padding="15" ColumnDefinitions="Auto,*,Auto,Auto">
                <Image Grid.Column="0" Source="logo.png" HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>

                <Label Grid.Column="1" />

                <Label Grid.Column="2" Text="🔔" FontSize="24" Margin="0,0,10,0" TextColor="Black" />

                <Label Grid.Column="3" Text="👤" FontSize="24" TextColor="Black">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="18">

                <!-- ✅ BACK BUTTON -->
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">

                    <Border BackgroundColor="#A855F7"
                            Stroke="White"
                            StrokeThickness="1.5"
                            Padding="12,6"
                            StrokeShape="RoundRectangle 18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>

                        <HorizontalStackLayout Spacing="5">
                            <Label Text="←" FontSize="16" TextColor="White" VerticalOptions="Center" />
                            <Label Text="Back" FontSize="14" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Label Text="REMOVE PRODUCT"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#B455FF" />
                </HorizontalStackLayout>

                <Label Text="Remove Product" TextColor="Gray" />

                <CollectionView x:Name="ProductsListView"
                                SelectionMode="Single"
                                HeightRequest="400">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout>
                                    <Label Text="{Binding Category}" FontSize="12" TextColor="Gray" />
                                    <Label Text="{Binding Name}" FontSize="18" TextColor="Black" />
                                    <Label Text="{Binding Stock, StringFormat='Stock: {0}'}" TextColor="Black" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#FF4D4D"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        StrokeThickness="0"
                                        Padding="5"
                                        VerticalOptions="Center">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20" />
                                    </Border.StrokeShape>

                                    <Label Text="🗑"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           TextColor="White" />
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

                <Button Text="SAVE CHANGES"
                        BackgroundColor="#F4B400"
                        TextColor="Black"
                        CornerRadius="20"
                        HeightRequest="55"
                        Clicked="OnRemoveSelectedClicked" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>