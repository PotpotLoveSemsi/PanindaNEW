<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Views.OrdersPage"
             BackgroundColor="#F2EFEF">

    <ScrollView>
        <VerticalStackLayout Spacing="15">

            <Grid BackgroundColor="#D9D9D9"
                  Padding="15"
                  ColumnDefinitions="Auto,*">

                <Image Grid.Column="0"
                       Source="logo.png"
                       HeightRequest="35">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoClicked" />
                    </Image.GestureRecognizers>
                </Image>

                <Label Grid.Column="1" />
            </Grid>

            <VerticalStackLayout Padding="20" Spacing="20">

                <HorizontalStackLayout Spacing="12">
                    <Border BackgroundColor="#A855F7"
                            Stroke="White"
                            StrokeThickness="1.5"
                            Padding="12,6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="← Back" TextColor="White"/>
                    </Border>

                    <Label Text="ORDERS"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#C084FC"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <CollectionView x:Name="OrdersList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#E6E1E1"
                                    StrokeThickness="0"
                                    Padding="15"
                                    Margin="0,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="5">
                                    <Label Text="{Binding OrderNumber}" TextColor="#A855F7" FontAttributes="Bold" FontSize="16"/>
                                    <Label Text="{Binding SupplierName, StringFormat='Supplier: {0}'}" TextColor="Black"/>
                                    <Label Text="Items Ordered:" TextColor="#D4A017"/>
                                    <Label Text="{Binding ItemsSummary}" TextColor="Black"/>
                                    <Label Text="{Binding Status, StringFormat='Status: {0}'}" TextColor="Black"/>
                                    <Label Text="{Binding ETA, StringFormat='ETA: {0}'}" TextColor="Black"/>
                                    <Label Text="{Binding TotalCost, StringFormat='Total Cost: ₱{0:N2}'}" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button x:Name="ShowMoreButton"
                        Text="SHOW MORE"
                        BackgroundColor="#A855F7"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="45"
                        IsVisible="False"
                        Clicked="OnShowMoreClicked"/>

                <Button Text="BACK TO DASHBOARD"
                        BackgroundColor="#FBBF24"
                        TextColor="Black"
                        CornerRadius="10"
                        HeightRequest="45"
                        Clicked="OnDashboardClicked"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>