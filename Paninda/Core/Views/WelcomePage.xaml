<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Paninda.Core.Views.WelcomePage"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <Label Text="Welcome to"
               FontSize="28"
               HorizontalOptions="Center"
               TextColor="Black"/>

        <Image Source="logo.png"
               HeightRequest="260"
               HorizontalOptions="Center"/>

        <Border BackgroundColor="White" Padding="20" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="12">
                <Button Text="Gumawa ng Account"
                        Clicked="OnSignupClicked"
                        BackgroundColor="#F4A300"
                        TextColor="Black"
                        FontAttributes="Bold"
                        CornerRadius="22"
                        HeightRequest="50"/>

                <Button Text="Mag Log-in"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#B455FF"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="22"
                        HeightRequest="50"/>
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentPage>